# ── POS SaaS Foundation R1 — 環境變數範例 ─────────────────────────────
# 複製為 .env 後依實際部署環境調整；.env 不應提交進版控。

# 伺服器埠號
PORT=5000

# JWT 簽章密鑰（正式環境務必更換為隨機字串，不要沿用程式內建的預設 fallback 值）
JWT_SECRET=replace-with-a-random-secret

# ── fix18-10-hotfix29-C2：資料備份／搬家 JSON 上傳大小上限 ──────────
# 只影響 POST /api/migration/import/preview 與 POST /api/migration/import
# 這兩條路徑，不影響全站其他 API 的 body size 限制（其餘 API 仍固定 5MB）。
#
# 規則（見 utils/migrationUploadLimit.js）：
#   - 預設 25MB（不設定此變數，或設定無效值時使用）
#   - 最低 1MB（低於 1 會被限制為 1）
#   - 最高硬性上限 100MB（設定超過 100 會被限制為 100，無法繞過）
#   - 非數字／空字串／NaN 一律回退為預設 25MB
#
# 範例：提高到 50MB
# MIGRATION_UPLOAD_LIMIT_MB=50
MIGRATION_UPLOAD_LIMIT_MB=25

# AI Marketing Center 反向代理相關（沿用既有設定，非本次修復範圍）
# AIMC_SERVICE_URL=http://localhost:4100
# INTERNAL_PROXY_SECRET=change-me-to-a-random-secret
